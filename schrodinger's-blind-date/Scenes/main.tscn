[sub_resource type="Animation" id="Animation_pfx1i"]
resource_name = "FightEnd"
length = 19.3833
tracks/0/type = "method"
tracks/0/imported = false
tracks/0/enabled = true
tracks/0/path = NodePath(".")
tracks/0/interp = 1
tracks/0/loop_wrap = true
tracks/0/keys = {
"times": PackedFloat32Array(0, 3.32, 8.32, 13.3333, 16.033333),
"transitions": PackedFloat32Array(1, 1, 1, 1, 1),
"values": [{
"args": [ExtResource("42_fg68e"), "Good thing that guy ran away, he isn't what he seems.", Color(0, 0, 0.5137255, 1), 5.0],
"method": &"nextVoice"
}, {
"args": [ExtResource("43_jekl6"), "I'm sure you've noticed him contradicting himself. Or maybe even sometimes two of him at once.", Color(0, 0, 0.5137255, 1), 5.0],
"method": &"nextVoice"
}, {
"args": [ExtResource("44_v1mrv"), "It's because he exsists in multiple states at once. He's a being beyond our realm of physics.", Color(0, 0, 0.5137255, 1), 5.0],
"method": &"nextVoice"
}, {
"args": [ExtResource("44_fd3ed"), "And his name... Isn't Schrodinger...", Color(0, 0, 0.5137255, 1), 5.0],
"method": &"nextVoice"
}, {
"args": [ExtResource("45_qnggo"), "It's Schrodaylan.", Color(0, 0, 0.5137255, 1), 8.0],
"method": &"nextVoice"
}]
}
